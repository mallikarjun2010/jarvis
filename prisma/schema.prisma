datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  name          String?
  avatar        String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  tokens        OAuthToken[]
  sessions      Session[]
  tasks         Task[]
  memories      Memory[]
  automations   AutomationJob[]
  conversations Conversation[]
  logs          Log[]
  settings      Setting?
}

model OAuthToken {
  id           String   @id @default(uuid())
  userId       String
  accessToken  String   // Encrypted
  refreshToken String?  // Encrypted
  expiryDate   DateTime
  scopes       String
  tokenType    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Memory {
  id        String   @id @default(uuid())
  userId    String
  category  String   // "PEOPLE", "PROJECT", "DEADLINE", "PREFERENCE", "GENERAL"
  content   String
  tags      String   // Comma separated tags
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String?
  status      String    @default("PENDING") // "PENDING", "COMPLETED"
  dueDate     DateTime?
  priority    String    @default("MEDIUM")  // "LOW", "MEDIUM", "HIGH"
  source      String    @default("MANUAL")  // "EMAIL", "CHAT", "MANUAL"
  sourceId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AutomationJob {
  id            String    @id @default(uuid())
  userId        String
  type          String    // "DAILY_PLAN", "EVENING_PREP", "EMAIL_DIGEST"
  status        String    @default("PENDING") // "PENDING", "RUNNING", "COMPLETED", "FAILED"
  scheduledTime DateTime
  runTime       DateTime?
  result        String?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  role           String       // "user", "assistant"
  content        String
  thoughts       String?      // AI internal monologue / thinking process
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Setting {
  id          String   @id @default(uuid())
  userId      String   @unique
  voiceOutput Boolean  @default(true)
  autoDigest  Boolean  @default(true)
  focusMode   Boolean  @default(false)
  customTheme String   @default("default")
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Log {
  id        String   @id @default(uuid())
  userId    String?
  type      String   // "SYSTEM", "GOOGLE_API", "GEMINI_API", "AUTOMATION"
  message   String
  status    String   // "INFO", "WARN", "ERROR"
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
